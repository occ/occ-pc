name: Build Nix Packages

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Install Nix
        uses: cachix/install-nix-action@v30
        with:
          nix_path: nixpkgs=channel:nixos-25.11
          extra_nix_config: |
            experimental-features = nix-command flakes
            allow-import-from-derivation = true

      - name: Build occ-desktop configuration
        run: |
          nix build .#nixosConfigurations.occ-desktop.config.system.build.toplevel --no-link

      - name: Build occ-laptop configuration
        run: |
          nix build .#nixosConfigurations.occ-laptop.config.system.build.toplevel --no-link

      - name: Build home-manager configuration
        run: |
          nix build .#homeConfigurations.occ.activationPackage --no-link

      - name: Create package manifest
        run: |
          mkdir -p artifacts
          nix path-info --json \
            .#nixosConfigurations.occ-desktop.config.system.build.toplevel \
            .#nixosConfigurations.occ-laptop.config.system.build.toplevel \
            .#homeConfigurations.occ.activationPackage > artifacts/build-manifest.json

      - name: Upload package manifest
        uses: actions/upload-artifact@v4
        with:
          name: nix-manifests
          path: artifacts/
          retention-days: 7
